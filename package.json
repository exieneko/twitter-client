{
  "name": "@exieneko/twitter-client",
  "description": "Twitter API client for Javascript",
  "version": "0.7.1",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "author": {
    "name": "exieneko",
    "email": "exieneko@proton.me"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/exieneko/twitter-client.git"
  },
  "bugs": "https://github.com/exieneko/twitter-client/issues",
  "files": [
    "dist/"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./types/internal": {
      "import": "./dist/types/internal/index.js",
      "types": "./dist/types/internal/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "pnpm build && node tests/index.test.js"
  },
  "license": "MIT",
  "keywords": [
    "twitter",
    "twitter-api"
  ],
  "packageManager": "pnpm@11.5.2",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "dotenv": "^17.4.2",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "node-color-log": "^14.0.0",
    "undici": "^8.7.0",
    "x-client-transaction-id": "^0.3.1"
  }
}
